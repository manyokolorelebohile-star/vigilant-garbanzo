# BMI Calculator

# Input
weight = float(input("Enter weight in kg: "))
height = float(input("Enter height in meters: "))

# BMI Formula
bmi = weight / (height * height)

# Output BMI
print("BMI =", round(bmi, 2))

# BMI Category
if bmi < 18.5:
    print("Underweight")
elif bmi < 25:
    print("Normal weight")
elif bmi < 30:
    print("Overweight")
else:
    print("Obese")
